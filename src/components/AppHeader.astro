---
// src/components/AppHeader.astro
---
<header class="app-header">
  <div class="logo-mark">✦</div>
  <h1 class="app-title">Phrase Paraphraser</h1>
  <p class="app-subtitle">
    Teks kamu melakukan perjalanan: <span class="lang-chain">ID → NL → EN → ID</span>
  </p>

  <div id="toastNotification" class="toast-toast hidden"></div>
</header>

<style>
  .app-header {
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.75rem;
    position: relative;
    width: 100%;
  }

  .logo-mark {
    font-size: 2rem;
    color: #f59e0b;
    line-height: 1;
  }

  .app-title {
    font-family: 'DM Serif Display', serif;
    font-size: clamp(2.2rem, 6vw, 3.2rem);
    font-weight: 400;
    color: #f8fafc;
    letter-spacing: -0.03em;
    line-height: 1.05;
    margin: 0;
  }

  .app-subtitle {
    font-size: 0.95rem;
    color: #94a3b8;
    font-weight: 300;
    margin: 0;
    max-width: 38rem;
    line-height: 1.6;
  }

  .lang-chain {
    color: #f59e0b;
    font-weight: 500;
    font-family: 'DM Serif Display', serif;
    font-style: italic;
  }

  .app-header::before { 
    content: ''; 
    position: absolute; 
    left: 50%; 
    top: -1rem; 
    transform: translateX(-50%); 
    width: 68px; 
    height: 4px; 
    background: linear-gradient(90deg, #f59e0b, #10b981); 
    border-radius: 2px; 
    opacity: 0.9; 
  }

  /* ✅ STYLING TOAST: Tegas, solid, performa tinggi */
  .toast-toast {
    position: fixed;
    top: 2rem;
    left: 50%;
    transform: translateX(-50%);
    background: #0f172a;
    border: 2px solid #f59e0b;
    color: #f8fafc;
    padding: 0.6rem 1.2rem;
    font-size: 0.85rem;
    font-weight: 600;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    box-shadow: 4px 4px 0px #020617;
    z-index: 9999;
    pointer-events: none;
    animation: toastFadeInOut 1.8s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }

  .toast-toast.hidden {
    display: none !important;
  }

  @keyframes toastFadeInOut {
    0% { opacity: 0; transform: translate(-50%, -10px); }
    15% { opacity: 1; transform: translate(-50%, 0); }
    85% { opacity: 1; transform: translate(-50%, 0); }
    100% { opacity: 0; transform: translate(-50%, -10px); }
  }
</style>