---
interface Props {
  steps?: {
    lang: string;
    flag: string;
    text: string;
  }[];
  loading?: boolean;
}

const { steps = [], loading = false } = Astro.props;
---

<div class="space-y-4">
  {/* Chain visualization */}
  <div class="flex items-center justify-between gap-2 mb-6 overflow-x-auto pb-2">
    <div class="flex items-center gap-2 min-w-fit">
      <div class="text-2xl">🇮🇩</div>
      <div class="w-6 h-0.5 bg-accent"></div>
    </div>
    <div class="flex items-center gap-2 min-w-fit">
      <div class="text-2xl">🇳🇱</div>
      <div class="w-6 h-0.5 bg-accent"></div>
    </div>
    <div class="flex items-center gap-2 min-w-fit">
      <div class="text-2xl">🇬🇧</div>
      <div class="w-6 h-0.5 bg-accent"></div>
    </div>
    <div class="text-2xl">🇮🇩</div>
  </div>

  {/* Steps content */}
  <div class="space-y-3">
    {steps.map((step, idx) => (
      <div
        class="p-4 rounded-lg border border-border bg-surface/50 hover:bg-surface/80 transition-colors animate-fadeIn"
        style={`animation-delay: ${idx * 100}ms`}
      >
        <div class="flex items-center gap-2 mb-2">
          <span class="text-2xl">{step.flag}</span>
          <span class="text-xs font-semibold text-accent uppercase tracking-wider">
            Step {idx + 1}
          </span>
        </div>
        <p class="text-sm leading-relaxed text-slate-300 break-words">
          {step.text}
        </p>
      </div>
    ))}

    {loading && (
      <div class="p-4 rounded-lg border border-border bg-surface/50">
        <div class="flex items-center gap-2">
          <div class="w-2 h-2 bg-accent rounded-full animate-pulse"></div>
          <span class="text-sm text-slate-400">Translating...</span>
        </div>
      </div>
    )}
  </div>
</div>

<style>
  @keyframes fadeIn {
    from {
      opacity: 0;
      transform: translateY(-8px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .animate-fadeIn {
    animation: fadeIn 0.4s ease-out forwards;
  }
</style>
