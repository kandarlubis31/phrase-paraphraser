---
// src/components/TranslateBox.astro
---

<div class="app-wrapper">
  <header class="app-header">
    <div class="logo-mark">✦</div>
    <h1 class="app-title">Phrase Paraphraser</h1>
    <p class="app-subtitle">
      Teks kamu melakukan perjalanan: <span class="lang-chain">ID → NL → EN → ID</span>
    </p>
  </header>

  <div class="card-main">
    <div class="input-section">
      <div class="section-label">
        <span class="flag">🇮🇩</span>
        <span>Teks Indonesia</span>
      </div>
      <textarea
        id="inputText"
        placeholder="Tulis teksmu di sini..."
        maxlength="500"
      ></textarea>
      <div class="char-row">
        <span id="charCount" class="char-count">0 / 500</span>
      </div>
    </div>

    <button id="paraphraseBtn" class="btn-paraphrase">
      <span id="btnLabel">Parafrasakan ✦</span>
      <span id="btnSpinner" class="spinner hidden"></span>
    </button>

    <div id="errorBox" class="error-box hidden"></div>

    <div id="results" class="results hidden">
      <div class="progress-chain">
        <div class="progress-step" id="step-0">
          <div class="progress-badge active" id="badge-0">
            <span class="flag">🇮🇩</span>
          </div>
          <div class="progress-content">
            <div class="progress-title">Indonesian (Original)</div>
            <p class="progress-text" id="progress-text-0"></p>
          </div>
        </div>

        <div class="progress-arrow">↓</div>

        <div class="progress-step" id="step-1">
          <div class="progress-badge" id="badge-1">
            <span class="flag">🇳🇱</span>
          </div>
          <div class="progress-content">
            <div class="progress-title">Dutch
              <span class="progress-status" id="status-1"></span>
            </div>
            <p class="progress-text" id="progress-text-1"></p>
          </div>
        </div>

        <div class="progress-arrow">↓</div>

        <div class="progress-step" id="step-2">
          <div class="progress-badge" id="badge-2">
            <span class="flag">🇬🇧</span>
          </div>
          <div class="progress-content">
            <div class="progress-title">English
              <span class="progress-status" id="status-2"></span>
            </div>
            <p class="progress-text" id="progress-text-2"></p>
          </div>
        </div>

        <div class="progress-arrow">↓</div>

        <div class="progress-step" id="step-3">
          <div class="progress-badge" id="badge-3">
            <span class="flag">🇮🇩</span>
          </div>
          <div class="progress-content">
            <div class="progress-title">Indonesian (Paraphrased)
              <span class="progress-status" id="status-3"></span>
            </div>
            <p class="progress-text" id="progress-text-3"></p>
          </div>
        </div>
      </div>

      <div class="result-actions">
        <button id="copyBtn" class="btn-copy">Salin Hasil Akhir</button>
      </div>
    </div>
  </div>

  <footer class="app-footer">
    Powered by MyMemory API · Astro · Vercel
  </footer>
</div>

<script>
  const MYMEMORY = 'https://api.mymemory.translated.net/get';
  let isProcessing = false;

  async function translate(text: string, src: string, tgt: string): Promise<string> {
    const controller = new AbortController();
    const timer = setTimeout(() => controller.abort(), 10_000);
    try {
      const res = await fetch(
        `${MYMEMORY}?q=${encodeURIComponent(text)}&langpair=${src}|${tgt}`,
        { signal: controller.signal }
      );
      if (!res.ok) throw new Error(`HTTP ${res.status}`);
      const data = await res.json();
      
      if (data.responseStatus === 200 || data.responseStatus === 206) {
        return data.responseData.translatedText || text;
      }
      
      if (data.responseStatus === 429 || data.responseStatus === 403) {
         throw new Error('Limit kuota terjemahan gratis hari ini tercapai.');
      }

      throw new Error(`Status ${data.responseStatus}: ${data.responseDetails || 'Unknown'}`);
    } finally {
      clearTimeout(timer);
    }
  }

  // Karena ini di dalam komponen Astro, kita pastikan DOM sudah ready
  document.addEventListener('DOMContentLoaded', () => {
    const textarea    = document.getElementById('inputText') as HTMLTextAreaElement;
    const btn         = document.getElementById('paraphraseBtn') as HTMLButtonElement;
    const btnLabel    = document.getElementById('btnLabel') as HTMLSpanElement;
    const btnSpinner  = document.getElementById('btnSpinner') as HTMLSpanElement;
    const charCount   = document.getElementById('charCount') as HTMLSpanElement;
    const errorBox    = document.getElementById('errorBox') as HTMLDivElement;
    const results     = document.getElementById('results') as HTMLDivElement;
    const copyBtn     = document.getElementById('copyBtn') as HTMLButtonElement;

    if (!textarea || !btn) return;

    textarea.addEventListener('input', () => {
      charCount.textContent = `${textarea.value.length} / 500`;
    });

    function setLoading(on: boolean) {
      isProcessing = on;
      btn.disabled = on;
      btnLabel.classList.toggle('hidden', on);
      btnSpinner.classList.toggle('hidden', !on);
    }

    function showError(msg: string) {
      errorBox.textContent = msg;
      errorBox.classList.remove('hidden');
      results.classList.add('hidden');
    }

    function hideError() {
      errorBox.classList.add('hidden');
    }

    function resetBadges() {
      [1, 2, 3].forEach(i => {
        const badge = document.getElementById(`badge-${i}`);
        const statusSpan = document.getElementById(`status-${i}`);
        const textSpan = document.getElementById(`progress-text-${i}`);
        
        if (badge) badge.classList.remove('loading', 'done', 'error');
        if (statusSpan) {
            statusSpan.textContent = '';
            statusSpan.style.animation = 'none';
        }
        if (textSpan) textSpan.textContent = '';
      });
    }

    function updateBadge(stepIdx: number, status: 'loading' | 'done' | 'error') {
      const badge = document.getElementById(`badge-${stepIdx}`);
      const statusSpan = document.getElementById(`status-${stepIdx}`);
      if (!badge || !statusSpan) return;

      badge.classList.remove('loading', 'done', 'error');
      badge.classList.add(status);

      if (status === 'loading') {
        statusSpan.textContent = ' ⟳';
        statusSpan.style.animation = 'spin 1s linear infinite';
      } else if (status === 'done') {
        statusSpan.textContent = ' ✓';
        statusSpan.style.color = '#10b981';
        statusSpan.style.animation = 'none';
      } else if (status === 'error') {
        statusSpan.textContent = ' ✕';
        statusSpan.style.color = '#ef4444';
        statusSpan.style.animation = 'none';
      }
    }

    btn.addEventListener('click', async () => {
      if (isProcessing) return;

      const text = textarea.value.trim();
      if (!text) {
        showError('Masukkan teks terlebih dahulu.');
        return;
      }

      setLoading(true);
      hideError();
      resetBadges();
      results.classList.add('hidden');

      try {
        const text0 = document.getElementById('progress-text-0');
        if (text0) text0.textContent = text;
        results.classList.remove('hidden');

        updateBadge(1, 'loading');
        const nlText = await translate(text, 'id', 'nl');
        const text1 = document.getElementById('progress-text-1');
        if (text1) text1.textContent = nlText;
        updateBadge(1, 'done');

        updateBadge(2, 'loading');
        const enText = await translate(nlText, 'nl', 'en');
        const text2 = document.getElementById('progress-text-2');
        if (text2) text2.textContent = enText;
        updateBadge(2, 'done');

        updateBadge(3, 'loading');
        const idText = await translate(enText, 'en', 'id');
        const text3 = document.getElementById('progress-text-3');
        if (text3) text3.textContent = idText;
        updateBadge(3, 'done');

        setTimeout(() => {
          results.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
        }, 100);
      } catch (err: unknown) {
        const msg = err instanceof Error ? err.message : String(err);
        showError(`Gagal menerjemahkan: ${msg}`);
        [1, 2, 3].forEach(i => {
          const badge = document.getElementById(`badge-${i}`);
          if (badge && badge.classList.contains('loading')) {
            updateBadge(i, 'error');
          }
        });
      } finally {
        setLoading(false);
      }
    });

    copyBtn.addEventListener('click', () => {
      const resultText = document.getElementById('progress-text-3');
      if (!resultText || !resultText.textContent) return;
      
      navigator.clipboard.writeText(resultText.textContent);
      const orig = copyBtn.textContent;
      copyBtn.textContent = 'Tersalin ✓';
      setTimeout(() => { copyBtn.textContent = orig; }, 2000);
    });
  });
</script>

<style>
  /* Hanya style untuk komponen ini, tanpa merusak body global */
  .app-wrapper {
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 3rem 1.5rem 4rem;
    gap: 2.5rem;
    font-family: 'DM Sans', sans-serif;
  }

  .app-header {
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.75rem;
  }

  .logo-mark {
    font-size: 2rem;
    color: #f59e0b;
    line-height: 1;
    animation: pulse-glow 3s ease-in-out infinite;
  }

  @keyframes pulse-glow {
    0%, 100% { text-shadow: 0 0 8px #f59e0b66; }
    50%      { text-shadow: 0 0 24px #f59e0bcc; }
  }

  @keyframes spin {
    to { transform: rotate(360deg); }
  }

  .app-title {
    font-family: 'DM Serif Display', serif;
    font-size: clamp(2.2rem, 6vw, 3.5rem);
    font-weight: 400;
    color: #f8fafc;
    letter-spacing: -0.02em;
    line-height: 1.1;
    margin: 0;
  }

  .app-subtitle {
    font-size: 0.95rem;
    color: #94a3b8;
    font-weight: 300;
    margin: 0;
  }

  .lang-chain {
    color: #f59e0b;
    font-weight: 500;
    font-family: 'DM Serif Display', serif;
    font-style: italic;
  }

  .card-main {
    width: 100%;
    max-width: 720px;
    background: rgba(15, 23, 42, 0.85);
    border: 1px solid rgba(248, 250, 252, 0.08);
    border-radius: 20px;
    padding: 2rem;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    backdrop-filter: blur(16px);
    box-shadow:
      0 0 0 1px rgba(245,158,11,0.05),
      0 20px 60px rgba(0,0,0,0.5),
      inset 0 1px 0 rgba(248,250,252,0.05);
  }

  .input-section {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .section-label {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.72rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: #64748b;
  }

  .flag { font-size: 1.1rem; }

  textarea {
    width: 100%;
    min-height: 120px;
    padding: 1rem 1.25rem;
    background: rgba(248,250,252,0.04);
    border: 1px solid rgba(248,250,252,0.1);
    border-radius: 12px;
    color: #f8fafc;
    font-family: 'DM Sans', sans-serif;
    font-size: 1rem;
    font-weight: 300;
    line-height: 1.7;
    resize: vertical;
    transition: border-color 0.2s, box-shadow 0.2s;
    box-sizing: border-box;
    caret-color: #f59e0b;
  }

  textarea::placeholder { color: #475569; }
  textarea:focus {
    outline: none;
    border-color: rgba(245,158,11,0.4);
    box-shadow: 0 0 0 3px rgba(245,158,11,0.08);
  }

  .char-row { display: flex; justify-content: flex-end; }
  .char-count { font-size: 0.72rem; color: #475569; font-variant-numeric: tabular-nums; }

  .btn-paraphrase {
    width: 100%;
    padding: 0.875rem 1.5rem;
    background: linear-gradient(135deg, #f59e0b, #d97706);
    border: none;
    border-radius: 12px;
    color: #0f172a;
    font-family: 'DM Sans', sans-serif;
    font-size: 0.95rem;
    font-weight: 600;
    letter-spacing: 0.02em;
    cursor: pointer;
    transition: all 0.2s;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    overflow: hidden;
  }

  .btn-paraphrase:hover { filter: brightness(1.1); }
  .btn-paraphrase:active { transform: scale(0.99); }
  .btn-paraphrase:disabled { opacity: 0.6; cursor: not-allowed; transform: none; }

  .spinner {
    width: 16px; height: 16px;
    border: 2px solid rgba(15,23,42,0.3);
    border-top-color: #0f172a;
    border-radius: 50%;
    animation: spin 0.7s linear infinite;
  }

  .hidden { display: none !important; }

  .error-box {
    padding: 0.875rem 1.25rem;
    background: rgba(239,68,68,0.08);
    border: 1px solid rgba(239,68,68,0.25);
    border-radius: 10px;
    color: #fca5a5;
    font-size: 0.875rem;
  }

  .results {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    border-top: 1px solid rgba(248,250,252,0.06);
    padding-top: 1.5rem;
    animation: fadeUp 0.4s ease-out;
  }

  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(10px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  .progress-chain {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .progress-step {
    display: flex;
    align-items: flex-start;
    gap: 1rem;
    padding: 1rem 1.25rem;
    background: rgba(248,250,252,0.03);
    border: 1px solid rgba(248,250,252,0.07);
    border-radius: 12px;
    transition: all 0.2s;
  }

  .progress-step:hover {
    background: rgba(248,250,252,0.05);
    border-color: rgba(248,250,252,0.12);
  }

  .progress-badge {
    flex-shrink: 0;
    width: 48px;
    height: 48px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 12px;
    background: rgba(245,158,11,0.1);
    border: 1.5px solid rgba(245,158,11,0.2);
    transition: all 0.3s;
    font-size: 1.5rem;
  }

  .progress-badge.active {
    background: rgba(245,158,11,0.15);
    border-color: rgba(245,158,11,0.4);
    box-shadow: 0 0 16px rgba(245,158,11,0.2);
  }

  .progress-badge.loading {
    border-color: #3b82f6;
    background: rgba(59,130,246,0.1);
    animation: pulse 1.5s ease-in-out infinite;
  }

  @keyframes pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.5; }
  }

  .progress-badge.done {
    background: rgba(16,185,129,0.1);
    border-color: #10b981;
    box-shadow: 0 0 12px rgba(16,185,129,0.2);
  }

  .progress-badge.error {
    background: rgba(239,68,68,0.1);
    border-color: #ef4444;
    box-shadow: 0 0 12px rgba(239,68,68,0.2);
  }

  .progress-content {
    flex: 1;
    min-width: 0;
  }

  .progress-title {
    font-size: 0.8rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: #94a3b8;
    margin-bottom: 0.5rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .progress-status {
    display: inline-block;
    font-size: 1rem;
    font-weight: 400;
  }

  .progress-text {
    font-size: 0.9rem;
    color: #cbd5e1;
    line-height: 1.6;
    margin: 0;
    font-weight: 300;
    word-break: break-word;
    white-space: pre-wrap;
    min-height: 1.5em;
  }

  .progress-arrow {
    text-align: center;
    color: #f59e0b;
    font-size: 1rem;
    margin: -0.5rem 0;
    opacity: 0.5;
  }

  .result-actions {
    display: flex;
    gap: 1rem;
    justify-content: center;
    padding-top: 0.5rem;
  }

  .btn-copy {
    font-size: 0.875rem;
    font-weight: 600;
    color: #0f172a;
    background: linear-gradient(135deg, #10b981, #059669);
    border: none;
    border-radius: 10px;
    padding: 0.625rem 1.5rem;
    cursor: pointer;
    transition: all 0.2s;
    font-family: 'DM Sans', sans-serif;
  }

  .btn-copy:hover {
    filter: brightness(1.1);
  }

  .btn-copy:active {
    transform: scale(0.98);
  }

  .app-footer {
    font-size: 0.72rem;
    color: #334155;
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }

  @media (max-width: 640px) {
    .app-wrapper { padding: 2rem 1rem 3rem; }
    .card-main { padding: 1.5rem; }
    .progress-badge { width: 40px; height: 40px; font-size: 1.2rem; }
    .progress-step { gap: 0.75rem; padding: 0.875rem 1rem; }
  }
</style>