---
// src/components/TranslateBox.astro
import AppHeader from "./AppHeader.astro";
import EditorialFeatures from "./EditorialFeatures.astro";
import FlowVisual from "./FlowVisual.astro";
import ResultProgress from "./ResultProgress.astro";
---

<div class="app-wrapper">
  <AppHeader />

  <EditorialFeatures />

  <FlowVisual />

  <div class="card-main">
    <div class="input-section">
      <div
        class="section-label"
        style="display:flex;justify-content:space-between;align-items:center;"
      >
        <div style="display:flex;align-items:center;gap:0.5rem;">
          <span class="flag">🇮🇩</span>
          <span>Teks Indonesia</span>
        </div>
        <div style="display:flex;gap:0.5rem;align-items:center;">
          <button id="pasteBtn" class="action-btn">Tempel</button>
          <button id="clearBtn" class="action-btn ghost">Bersihkan</button>
        </div>
      </div>
      <textarea
        id="inputText"
        placeholder="Tulis teksmu di sini..."
        maxlength="3000"></textarea>
      <div class="char-row">
        <span id="charCount" class="char-count">0 / 3000</span>
      </div>
    </div>

    <button id="paraphraseBtn" class="btn-paraphrase">
      <span id="btnLabel">Parafrasakan ✦</span>
      <span id="btnSpinner" class="spinner hidden"></span>
    </button>

    <div id="errorBox" class="error-box hidden"></div>

    <ResultProgress />
  </div>

  <button id="goUpBtn" class="btn-go-up hidden" aria-label="Kembali ke atas"
    >↑</button
  >

  <footer class="app-footer">
    © 2026 Phrase Paraphraser · Powered by Back-Translation ·
    <a
      href="https://www.instagram.com/kandar.lubis31"
      target="_blank"
      rel="noopener">@kandar.lubis31</a
    >
    · <a href="https://github.com/kandarlubis31" target="_blank" rel="noopener"
      >GitHub</a
    >
    · <a href="https://www.paklubis.my.id" target="_blank" rel="noopener"
      >paklubis.my.id</a
    >
  </footer>
</div>

<script>
  const WORKER_URL = "https://phrase-proxy.kandarlubis31.workers.dev";
  let isProcessing = false;

  async function translate(
    text: string,
    src: string,
    tgt: string,
  ): Promise<string> {
    const controller = new AbortController();
    const timer = setTimeout(() => controller.abort(), 12_000);
    try {
      const res = await fetch(`${WORKER_URL}?t=${Date.now()}`, {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ text, src, tgt }),
        signal: controller.signal,
      });

      const data = await res.json();
      if (!res.ok) throw new Error(data.error || `HTTP ${res.status}`);
      return data.result;
    } finally {
      clearTimeout(timer);
    }
  }

  function initParaphraser() {
    const textarea = document.getElementById(
      "inputText",
    ) as HTMLTextAreaElement;
    const btn = document.getElementById("paraphraseBtn") as HTMLButtonElement;
    const btnLabel = document.getElementById("btnLabel") as HTMLSpanElement;
    const btnSpinner = document.getElementById("btnSpinner") as HTMLSpanElement;
    const charCount = document.getElementById("charCount") as HTMLSpanElement;
    const errorBox = document.getElementById("errorBox") as HTMLDivElement;
    const results = document.getElementById("results") as HTMLDivElement;
    const copyBtn = document.getElementById("copyBtn") as HTMLButtonElement;
    const dropdown = document.querySelector(
      ".process-dropdown",
    ) as HTMLDetailsElement;

    const pasteBtn = document.getElementById("pasteBtn") as HTMLButtonElement;
    const clearBtn = document.getElementById("clearBtn") as HTMLButtonElement;
    const goUpBtn = document.getElementById("goUpBtn") as HTMLButtonElement;

    const nodeNl = document.querySelector(".node-nl");
    const nodeEn = document.querySelector(".node-en");
    const nodeFinal = document.querySelector(".node-final");

    if (!textarea || !btn) return;

    if (results) results.style.setProperty("display", "none", "important");

    const savedInput = localStorage.getItem("paraphrase_input");
    const savedOutput = localStorage.getItem("paraphrase_output");
    const savedNl = localStorage.getItem("paraphrase_nl");
    const savedEn = localStorage.getItem("paraphrase_en");

    if (savedInput) {
      textarea.value = savedInput;
      handleCharCount();
    }

    if (savedOutput && results) {
      results.style.setProperty("display", "flex", "important");

      const t0 = document.getElementById("progress-text-0");
      const t1 = document.getElementById("progress-text-1");
      const t2 = document.getElementById("progress-text-2");
      const t3 = document.getElementById("progress-text-3");
      const s3 = document.getElementById("status-3");

      if (t0) t0.textContent = savedInput;
      if (t1) t1.textContent = savedNl;
      if (t2) t2.textContent = savedEn;
      if (t3) t3.textContent = savedOutput;

      if (s3) {
        s3.textContent = "✓ BERHASIL DIPARAFRASE";
        s3.style.color = "#10b981";
      }

      [1, 2, 3].forEach((i) => {
        const badge = document.getElementById(`badge-${i}`);
        if (badge) badge.classList.add("done");
      });
    }

    textarea.removeEventListener("input", handleCharCount);
    textarea.addEventListener("input", handleCharCount);
    // ✅ Pemicu Toast pas User pencet Ctrl + V atau Klik Kanan -> Tempel
    textarea.addEventListener("paste", () => {
      // Kasih delay tipis 50ms biar teksnya masuk utuh ke textarea dulu baru toast nongol
      setTimeout(() => {
        handleCharCount();
        showToast("✓ TEKS BERHASIL DITEMPEL");
      }, 50);
    });
    textarea.addEventListener("keydown", (e) => {
      if ((e.ctrlKey || e.metaKey) && e.key === "Enter") {
        e.preventDefault();
        btn.click();
      }
    });

    function handleCharCount() {
      if (charCount && textarea) {
        charCount.textContent = `${textarea.value.length} / 3000`;
        localStorage.setItem("paraphrase_input", textarea.value);
      }
    }

    function setLoading(on: boolean) {
      isProcessing = on;
      if (btn) btn.disabled = on;
      if (btnLabel) btnLabel.classList.toggle("hidden", on);
      if (btnSpinner) btnSpinner.classList.toggle("hidden", !on);
    }

    function showError(msg: string) {
      if (errorBox) {
        errorBox.textContent = msg;
        errorBox.classList.remove("hidden");
      }
      if (results) results.style.setProperty("display", "none", "important");
    }

    function hideError() {
      if (errorBox) errorBox.classList.add("hidden");
    }

    function resetBadges() {
      [1, 2, 3].forEach((i) => {
        const badge = document.getElementById(`badge-${i}`);
        const statusSpan = document.getElementById(`status-${i}`);
        const textSpan = document.getElementById(`progress-text-${i}`);

        if (badge) badge.classList.remove("loading", "done", "error");
        if (statusSpan) {
          statusSpan.textContent = "";
          statusSpan.style.animation = "none";
          statusSpan.style.color = "";
        }
        if (textSpan) textSpan.textContent = "";
      });

      if (nodeNl) nodeNl.classList.remove("processing");
      if (nodeEn) nodeEn.classList.remove("processing");
      if (nodeFinal) nodeFinal.classList.remove("processing");
    }

    function updateBadge(
      stepIdx: number,
      status: "loading" | "done" | "error",
    ) {
      const badge = document.getElementById(`badge-${stepIdx}`);
      const statusSpan = document.getElementById(`status-${stepIdx}`);
      if (!badge || !statusSpan) return;

      badge.classList.remove("loading", "done", "error");
      badge.classList.add(status);

      if (status === "loading") {
        statusSpan.textContent = " ⟳";
        statusSpan.style.animation = "spin 1s linear infinite";
      } else if (status === "done") {
        statusSpan.textContent = " ✓";
        statusSpan.style.color = "#10b981";
        statusSpan.style.animation = "none";
      } else if (status === "error") {
        statusSpan.textContent = " ✕";
        statusSpan.style.color = "#ef4444";
        statusSpan.style.animation = "none";
      }
    }

    if (clearBtn) {
      clearBtn.onclick = () => {
        textarea.value = "";
        handleCharCount();
        hideError();
        resetBadges();
        localStorage.clear();
        showToast("✕ KALIMAT DIBERSIHKAN");
        if (results) results.style.setProperty("display", "none", "important");
      };
    }

    if (pasteBtn) {
      pasteBtn.onclick = async () => {
        try {
          const text = await navigator.clipboard.readText();
          textarea.value = text;
          handleCharCount();
          showToast("✓ TEKS BERHASIL DITEMPEL");
        } catch (e) {}
      };
    }

    if (goUpBtn) {
      goUpBtn.onclick = () => {
        window.scrollTo({ top: 0, behavior: "smooth" });
      };

      window.onscroll = () => {
        if (
          document.body.scrollTop > 400 ||
          document.documentElement.scrollTop > 400
        ) {
          goUpBtn.classList.remove("hidden");
        } else {
          goUpBtn.classList.add("hidden");
        }
      };
    }

    btn.removeEventListener("click", handleParaphrase);
    btn.addEventListener("click", handleParaphrase);

    async function handleParaphrase() {
      if (isProcessing) return;

      const text = textarea.value.trim();
      if (!text) {
        showError("Masukkan teks terlebih dahulu.");
        return;
      }

      setLoading(true);
      hideError();
      resetBadges();
      if (dropdown) dropdown.open = false;
      if (results) results.style.setProperty("display", "none", "important");

      const status3 = document.getElementById("status-3");

      try {
        const text0 = document.getElementById("progress-text-0");
        if (text0) text0.textContent = text;

        if (results) results.style.setProperty("display", "flex", "important");

        setTimeout(() => {
          if (results)
            results.scrollIntoView({ behavior: "smooth", block: "center" });
        }, 80);

        // Step 1: ID → NL
        if (status3) {
          status3.textContent = "— MEMPROSES (1/3)";
          status3.style.color = "#f59e0b";
        }
        updateBadge(1, "loading");
        if (nodeNl) nodeNl.classList.add("processing");
        const nlText = await translate(text, "id", "nl");
        const text1 = document.getElementById("progress-text-1");
        if (text1) text1.textContent = nlText;
        updateBadge(1, "done");
        if (nodeNl) nodeNl.classList.remove("processing");

        // Step 2: NL → EN
        if (status3) {
          status3.textContent = "— MEMPROSES (2/3)";
          status3.style.color = "#f59e0b";
        }
        updateBadge(2, "loading");
        if (nodeEn) nodeEn.classList.add("processing");
        const enText = await translate(nlText, "nl", "en");
        const text2 = document.getElementById("progress-text-2");
        if (text2) text2.textContent = enText;
        updateBadge(2, "done");
        if (nodeEn) nodeEn.classList.remove("processing");

        // Step 3: EN → ID
        if (status3) {
          status3.textContent = "— MENYUSUN HASIL (3/3)";
          status3.style.color = "#f59e0b";
        }
        updateBadge(3, "loading");
        if (nodeFinal) nodeFinal.classList.add("processing");
        const idText = await translate(enText, "en", "id");
        const text3 = document.getElementById("progress-text-3");
        if (text3) text3.textContent = idText;
        updateBadge(3, "done");
        if (nodeFinal) nodeFinal.classList.remove("processing");

        localStorage.setItem("paraphrase_input", text);
        localStorage.setItem("paraphrase_nl", nlText);
        localStorage.setItem("paraphrase_en", enText);
        localStorage.setItem("paraphrase_output", idText);

        if (status3) {
          status3.textContent = "✓ BERHASIL DIPARAFRASE";
          status3.style.color = "#10b981";
        }

        setTimeout(() => {
          if (results)
            results.scrollIntoView({ behavior: "smooth", block: "nearest" });
        }, 150);
      } catch (err: unknown) {
        const msg = err instanceof Error ? err.message : String(err);
        showError(`Gagal menerjemahkan: ${msg}`);
        if (dropdown) dropdown.open = true;

        if (status3) {
          status3.textContent = "✕ GAGAL";
          status3.style.color = "#ef4444";
        }

        [1, 2, 3].forEach((i) => {
          const badge = document.getElementById(`badge-${i}`);
          if (badge && badge.classList.contains("loading")) {
            updateBadge(i, "error");
          }
        });
        if (nodeNl) nodeNl.classList.remove("processing");
        if (nodeEn) nodeEn.classList.remove("processing");
        if (nodeFinal) nodeFinal.classList.remove("processing");
      } finally {
        setLoading(false);
      }
    }

    if (copyBtn) {
      copyBtn.replaceWith(copyBtn.cloneNode(true));
      const freshCopyBtn = document.getElementById(
        "copyBtn",
      ) as HTMLButtonElement;

      freshCopyBtn.addEventListener("click", () => {
        const resultText = document.getElementById("progress-text-3");
        if (!resultText || !resultText.textContent) return;

        navigator.clipboard.writeText(resultText.textContent);
        const orig = freshCopyBtn.textContent;
        freshCopyBtn.textContent = "Tersalin ✓";
        setTimeout(() => {
          freshCopyBtn.textContent = orig;
        }, 2000);
      });
    }
  }

  document.addEventListener("DOMContentLoaded", initParaphraser);
  document.addEventListener("astro:page-load", initParaphraser);

  function showToast(message: string) {
    const toast = document.getElementById("toastNotification");
    if (!toast) return;

    const newToast = toast.cloneNode(true) as HTMLDivElement;
    newToast.textContent = message;
    newToast.classList.remove("hidden");

    toast.parentNode?.replaceChild(newToast, toast);

    setTimeout(() => {
      newToast.classList.add("hidden");
    }, 1800);
  }
</script>

<style>
  .app-wrapper {
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 2rem 1.5rem 3rem;
    gap: 1.5rem;
    font-family: "DM Sans", sans-serif;
    color: #e2e8f0;
  }

  .card-main {
    width: 100%;
    max-width: 720px;
    background: #0b1329;
    border: 2px solid #1e293b;
    border-radius: 18px;
    padding: 2rem;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    box-shadow: 8px 8px 0px #020617;
  }

  .input-section {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .section-label {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.72rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: #64748b;
  }

  .flag {
    font-size: 1.1rem;
  }

  textarea {
    width: 100%;
    min-height: 130px;
    padding: 1rem 1.15rem 1.25rem;
    background: #071122;
    border: 1px solid #334155;
    border-radius: 14px;
    color: #e2e8f0;
    font-family: "DM Sans", sans-serif;
    font-size: 0.95rem;
    font-weight: 300;
    line-height: 1.7;
    resize: vertical;
    transition:
      border-color 0.18s ease,
      box-shadow 0.18s ease,
      transform 0.18s ease;
    box-sizing: border-box;
    caret-color: #f59e0b;
  }

  textarea::placeholder {
    color: #475569;
    font-size: 15px;
  }

  textarea:focus {
    outline: none;
    border-color: #f59e0b;
    box-shadow: inset 0 2px 6px rgba(0, 0, 0, 0.55);
    transform: translateY(-1px);
    background: #020617;
  }

  .char-row {
    display: flex;
    justify-content: flex-end;
  }

  .char-count {
    font-size: 0.72rem;
    color: #475569;
    font-variant-numeric: tabular-nums;
  }

  .btn-paraphrase {
    width: 100%;
    padding: 0.95rem 1.5rem;
    background: #0f172a;
    border: 2px solid #f59e0b;
    color: #f8fafc;
    font-family: "DM Sans", sans-serif;
    font-size: 0.95rem;
    font-weight: 700;
    letter-spacing: 0.05em;
    cursor: pointer;
    transition:
      transform 0.18s ease,
      box-shadow 0.18s ease,
      background 0.18s ease;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
  }

  .btn-paraphrase:hover {
    background: #111827;
    transform: scale(1.005);
    box-shadow: 0 12px 40px rgba(245, 158, 11, 0.1);
  }

  .btn-paraphrase:active {
    transform: scale(0.99);
  }

  .btn-paraphrase:disabled {
    opacity: 0.55;
    cursor: not-allowed;
  }

  .spinner {
    width: 20px;
    height: 4px;
    border-radius: 999px;
    background: linear-gradient(90deg, transparent, #f59e0b, transparent);
    animation: pulse-soft 1s ease-in-out infinite;
  }

  .action-btn {
    background: #071226;
    border: 1px solid #334155;
    color: #e2e8f0;
    padding: 0.35rem 0.6rem;
    border-radius: 8px;
    font-size: 0.85rem;
    cursor: pointer;
    transition:
      transform 0.12s ease,
      border-color 0.12s ease;
  }

  .action-btn:hover {
    transform: translateY(-2px);
    border-color: #f59e0b;
  }

  .action-btn.ghost {
    background: transparent;
    border-style: dashed;
    color: #94a3b8;
  }

  .btn-go-up {
    position: fixed;
    bottom: 2rem;
    right: 2rem;
    z-index: 99;
    background: #0f172a;
    border: 2px solid #f59e0b;
    color: #f8fafc;
    width: 45px;
    height: 45px;
    border-radius: 10px;
    font-size: 1.2rem;
    font-weight: bold;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 4px 4px 0px #020617;
    transition:
      transform 0.15s ease,
      box-shadow 0.15s ease,
      background 0.15s ease;
  }

  .btn-go-up:hover {
    background: #111827;
    transform: translateY(-2px);
    box-shadow: 6px 6px 0px #020617;
  }

  .btn-go-up:active {
    transform: translateY(0px);
    box-shadow: 2px 2px 0px #020617;
  }

  .hidden {
    display: none !important;
  }

  .error-box {
    padding: 0.95rem 1.25rem;
    background: rgba(239, 68, 68, 0.08);
    border: 1px solid rgba(239, 68, 68, 0.25);
    border-left: 4px solid #ef4444;
    border-radius: 10px;
    color: #fca5a5;
    font-size: 0.9rem;
  }

  .app-footer {
    font-size: 0.72rem;
    color: #475569;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .app-footer a {
    color: #f8fafc;
    text-decoration: none;
    border-bottom: 1px dashed rgba(248, 250, 252, 0.4);
    transition:
      color 0.2s ease,
      border-color 0.2s ease;
  }

  .app-footer a:hover {
    color: #f59e0b;
    border-color: #f59e0b;
  }

  @keyframes pulse-soft {
    0%,
    100% {
      opacity: 0.3;
    }
    50% {
      opacity: 1;
    }
  }

  @keyframes spin {
    from {
      transform: rotate(0deg);
    }
    to {
      transform: rotate(360deg);
    }
  }

  @media (max-width: 640px) {
    .app-wrapper {
      padding: 1rem 0.5rem 2rem;
      width: 100%;
      overflow-x: hidden;
      box-sizing: border-box;
    }

    .card-main {
      padding: 1rem;
      width: 100%;
      box-shadow: 4px 4px 0px #020617;
      box-sizing: border-box;
    }

    .btn-go-up {
      bottom: 1.5rem;
      right: 1.5rem;
      width: 40px;
      height: 40px;
      font-size: 1.1rem;
    }

    :global(.flow-visual) {
      flex-wrap: wrap !important;
      justify-content: center !important;
      gap: 0.4rem !important;
    }

    :global(.flow-node) {
      font-size: 0.75rem !important;
      padding: 0.2rem 0.4rem !important;
    }

    :global(.flow-connector) {
      font-size: 0.75rem !important;
    }
  }
</style>
