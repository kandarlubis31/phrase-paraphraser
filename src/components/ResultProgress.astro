---
// src/components/ResultProgress.astro
---
<div id="results" class="results hidden" style="display: none !important;">
  
  <div class="progress-step final-result-box" id="step-3">
    <div class="progress-badge" id="badge-3">
      <span class="flag">🇮🇩</span>
    </div>
    <div class="progress-content">
      <div class="progress-title">Hasil Parafrase (Indonesia)
        <span class="progress-status" id="status-3"></span>
      </div>
      <p class="progress-text" id="progress-text-3"></p>
    </div>
  </div>

  <details class="process-dropdown">
    <summary class="dropdown-trigger">
      <span>Lihat Detail Proses Perjalanan Bahasa</span>
      <span class="chevron">↓</span>
    </summary>
    
    <div class="dropdown-content">
      <div class="progress-chain">
        <div class="progress-step" id="step-0">
          <div class="progress-badge active" id="badge-0">
            <span class="flag">🇮🇩</span>
          </div>
          <div class="progress-content">
            <div class="progress-title">Indonesian (Original)</div>
            <p class="progress-text" id="progress-text-0"></p>
          </div>
        </div>

        <div class="progress-arrow">↓</div>

        <div class="progress-step" id="step-1">
          <div class="progress-badge" id="badge-1">
            <span class="flag">🇳🇱</span>
          </div>
          <div class="progress-content">
            <div class="progress-title">Dutch
              <span class="progress-status" id="status-1"></span>
            </div>
            <p class="progress-text" id="progress-text-1"></p>
          </div>
        </div>

        <div class="progress-arrow">↓</div>

        <div class="progress-step" id="step-2">
          <div class="progress-badge" id="badge-2">
            <span class="flag">🇬🇧</span>
          </div>
          <div class="progress-content">
            <div class="progress-title">English
              <span class="progress-status" id="status-2"></span>
            </div>
            <p class="progress-text" id="progress-text-2"></p>
          </div>
        </div>
      </div>
    </div>
  </details>

  <div class="result-actions">
    <button id="copyBtn" class="btn-copy">Salin Hasil Akhir</button>
  </div>
</div>

<style>
  .results {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    border-top: 1px solid rgba(148, 163, 184, 0.12);
    padding-top: 1.5rem;
    animation: fadeUp 0.4s ease-out;
  }

  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(10px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .process-dropdown {
    background: #071226;
    border: 1px solid #1e293b;
    border-radius: 12px;
    overflow: hidden;
    transition: border-color 0.2s;
  }
  
  .process-dropdown[open] {
    border-color: #334155;
  }

  .dropdown-trigger {
    padding: 0.85rem 1.25rem;
    font-size: 0.85rem;
    color: #94a3b8;
    font-weight: 500;
    cursor: pointer;
    user-select: none;
    display: flex;
    justify-content: space-between;
    align-items: center;
    list-style: none;
  }

  .dropdown-trigger::-webkit-details-marker {
    display: none;
  }

  .process-dropdown[open] .chevron {
    transform: rotate(180deg);
  }

  .chevron {
    color: #f59e0b;
    font-weight: bold;
    transition: transform 0.2s ease;
  }

  .dropdown-content {
    padding: 1rem 1.25rem;
    border-top: 1px solid #1e293b;
    background: #050c1a;
  }

  .progress-chain {
    display: flex;
    flex-direction: column;
    gap: 0.9rem;
  }

  .progress-step {
    display: flex;
    align-items: flex-start;
    gap: 1rem;
    padding: 1rem 1.25rem;
    background: #07172f;
    border: 1px solid #1e293b;
    border-radius: 16px;
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.03);
    transition: border-color 0.2s ease, transform 0.2s ease;
  }

  /* ✅ MODIFIKASI: Box hasil akhir punya efek glow tipis di awal */
  .final-result-box {
    border: 2px solid rgba(16, 185, 129, 0.15);
    background: linear-gradient(180deg, #071c35, #07172f);
    position: relative;
  }

  /* ✅ ANIMASI BARU: Jika badge status selesai (done), aktifkan glow pulse hijau intensif */
  .final-result-box:has(.progress-badge.done) {
    border-color: #10b981;
    animation: glowSuccess 2s infinite alternate;
  }

  @keyframes glowSuccess {
    from { box-shadow: 0 0 4px rgba(16, 185, 129, 0.2); }
    to { box-shadow: 0 0 16px rgba(16, 185, 129, 0.4); }
  }

  .progress-step:hover {
    transform: translateX(1px);
    border-color: #334155;
  }

  .progress-badge {
    flex-shrink: 0;
    width: 48px;
    height: 48px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 12px;
    background: #0f172a;
    border: 2px solid #334155;
    transition: transform 0.25s ease, border-color 0.25s ease;
    font-size: 1.5rem;
  }

  .progress-badge.active {
    border-color: #f59e0b;
    transform: translateY(-1px);
  }

  .progress-badge.loading {
    animation: pulse-soft 1s ease-in-out infinite;
    background: #111827;
    border-color: #3b82f6;
  }

  .progress-badge.done {
    border-color: #10b981;
    background: #081f16;
  }

  .progress-badge.error {
    border-color: #ef4444;
    background: #2b0b0b;
  }

  .progress-content {
    flex: 1;
    min-width: 0;
  }

  .progress-title {
    font-family: 'DM Serif Display', serif;
    font-size: 0.95rem;
    font-weight: 400;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: #cbd5e1;
    margin-bottom: 0.5rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  /* ✅ STYLING BARU: Label teks notifikasi progress agar tegas */
  .progress-status {
    display: inline-block;
    font-size: 0.85rem;
    font-weight: 600;
    font-family: 'DM Sans', sans-serif;
    color: #f59e0b;
    margin-left: auto;
    letter-spacing: 0.05em;
  }

  .progress-text {
    font-family: 'DM Serif Display', serif;
    font-size: 1rem;
    letter-spacing: 0.01em;
    color: #e2e8f0;
    line-height: 1.75;
    margin: 0;
    font-weight: 300;
    word-break: break-word;
    white-space: pre-wrap;
    min-height: 1.75em;
  }

  .progress-arrow {
    position: relative;
    height: 42px;
    margin: 0;
    opacity: 0.55;
  }

  .progress-arrow::before {
    content: '';
    position: absolute;
    left: 50%;
    top: 0;
    transform: translateX(-50%);
    width: 0;
    height: 100%;
    border-left: 2px dashed #475569;
  }

  .progress-arrow {
    color: transparent;
  }

  .btn-copy {
    font-size: 0.875rem;
    font-weight: 700;
    color: #e2e8f0;
    background: #0f172a;
    border: 2px solid #10b981;
    border-radius: 12px;
    padding: 0.75rem 1.5rem;
    cursor: pointer;
    transition: transform 0.2s ease, background 0.2s ease;
    font-family: 'DM Sans', sans-serif;
  }

  .btn-copy:hover {
    background: #111827;
    transform: translateY(-1px);
  }

  .btn-copy:active {
    transform: scale(0.98);
  }

  @keyframes pulse-soft {
    0%, 100% { opacity: 0.3; }
    50% { opacity: 1; }
  }

  @media (max-width: 640px) {
    .progress-badge { width: 40px; height: 40px; font-size: 1.2rem; }
    .progress-step { gap: 0.75rem; padding: 0.95rem 1rem; }
    .progress-arrow::before { height: 34px; }
  }
</style>